Options -MultiViews
RewriteEngine On
RewriteBase /

# API: rutas sin extensión → PHP
RewriteRule ^api/contact$    api/contact.php    [L]
RewriteRule ^api/newsletter$ api/newsletter.php [L]

# SPA: todo lo que no sea un fichero o directorio real → index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
